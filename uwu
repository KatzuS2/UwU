import { useEffect, useMemo, useState } from "react";

export default function AmorEnLaUno() {
  const [currentChapter, setCurrentChapter] = useState(1);
  const [currentPage, setCurrentPage] = useState(0);
  const [doublePage, setDoublePage] = useState(true);

  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [isLogged, setIsLogged] = useState(false);

  const [uploadedPages, setUploadedPages] = useState(() => {
    const saved = localStorage.getItem("amor-en-la-uno-pages");
    return saved ? JSON.parse(saved) : {};
  });

  const [uploadedDocument, setUploadedDocument] = useState(() => {
    const saved = localStorage.getItem("amor-en-la-uno-document");
    return saved ? JSON.parse(saved) : null;
  });

  const [selectedImageIndex, setSelectedImageIndex] = useState(null);

  const [moveToChapter, setMoveToChapter] = useState(1);
  const [moveToPage, setMoveToPage] = useState(1);

  const [imageSize, setImageSize] = useState(100);
  const [imageBrightness, setImageBrightness] = useState(100);

  const [chapterTitle, setChapterTitle] = useState("");
  const [chapterNote, setChapterNote] = useState("");
  const [dedication, setDedication] = useState("");

  const chapters = [1, 2, 3, 4, 5, 6];

  const mangaData = useMemo(
    () => ({
      1: [],
      2: [],
      3: [],
      4: [],
      5: [],
      6: [],
    }),
    []
  );

  const pages =
    uploadedPages[currentChapter] || mangaData[currentChapter] || [];

  const totalPages = pages.length;

  useEffect(() => {
    const savedLogin = localStorage.getItem("amor-en-la-uno-admin");

    if (savedLogin === "true") {
      setIsLogged(true);
    }
  }, []);

  const ADMIN_EMAIL = "adminuwu";
  const ADMIN_PASSWORD = "admin123uwu";

  const handleLogin = (e) => {
    e.preventDefault();

    if (
      email === ADMIN_EMAIL &&
      password === ADMIN_PASSWORD
    ) {
      setIsLogged(true);
      localStorage.setItem("amor-en-la-uno-admin", "true");
    } else {
      alert("❌ Usuario o contraseña incorrectos");
    }
  };

  const uploadChapter = async (e) => {
    const files = Array.from(e.target.files);

    if (!files.length) return;

    const imagePromises = files.map(
      (file) =>
        new Promise((resolve) => {
          const reader = new FileReader();

          reader.onload = (event) => {
            resolve(event.target.result);
          };

          reader.readAsDataURL(file);
        })
    );

    const imageUrls = await Promise.all(imagePromises);

    setUploadedPages((prev) => {
      const updated = { ...prev };

      const targetChapter = moveToChapter;
      const existingPages = [...(updated[targetChapter] || [])];

      imageUrls.forEach((image, idx) => {
        const insertIndex = Math.max(0, moveToPage - 1 + idx);

        existingPages.splice(insertIndex, 0, image);
      });

      updated[targetChapter] = existingPages;

      localStorage.setItem(
        "amor-en-la-uno-pages",
        JSON.stringify(updated)
      );

      return updated;
    });

    setCurrentChapter(moveToChapter);
    setCurrentPage(Math.max(0, moveToPage - 1));

    e.target.value = "";

    alert(`✨ ${files.length} imágenes agregadas correctamente`);
  };

  const nextPage = () => {
    const step = doublePage ? 2 : 1;

    if (currentPage + step < pages.length) {
      setCurrentPage(currentPage + step);
    }
  };

  const previousPage = () => {
    const step = doublePage ? 2 : 1;

    if (currentPage - step >= 0) {
      setCurrentPage(currentPage - step);
    }
  };

  const visiblePages = doublePage
    ? pages.slice(currentPage, currentPage + 2)
    : pages.slice(currentPage, currentPage + 1);

  return (
    <div className="min-h-screen bg-gradient-to-b from-pink-100 via-purple-100 to-blue-100 overflow-hidden relative text-gray-800">
      <div className="fixed right-4 top-4 z-[999]">
        {!isLogged ? (
          <form
            onSubmit={handleLogin}
            className="bg-white/80 backdrop-blur-xl rounded-3xl shadow-2xl border border-white/60 p-5 flex flex-col gap-3 w-[280px]"
          >
            <h2 className="font-black text-xl text-pink-500">
              Login Admin ✨
            </h2>

            <input
              type="text"
              placeholder="Usuario"
              value={email}
              onChange={(e) => setEmail(e.target.value)}
              className="px-4 py-3 rounded-2xl outline-none border border-pink-200"
            />

            <input
              type="password"
              placeholder="Contraseña"
              value={password}
              onChange={(e) => setPassword(e.target.value)}
              className="px-4 py-3 rounded-2xl outline-none border border-pink-200"
            />

            <button className="bg-gradient-to-r from-pink-400 to-purple-400 text-white py-3 rounded-2xl font-bold">
              Iniciar sesión 💖
            </button>
          </form>
        ) : (
          <div className="bg-white/80 backdrop-blur-xl rounded-3xl shadow-2xl border border-white/60 p-5 flex flex-col gap-3 w-[320px] max-h-[90vh] overflow-y-auto">

            <h2 className="font-black text-xl text-purple-500">
              Panel Admin 🌸
            </h2>

            {/* Acá sigue TODO el panel admin */}
          </div>
        )}
      </div>

      <header className="sticky top-0 z-50 backdrop-blur-xl bg-white/50 border-b border-pink-200 shadow-sm">
        <div className="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-4">

          <h1 className="text-5xl font-black bg-gradient-to-r from-pink-500 via-purple-500 to-blue-500 bg-clip-text text-transparent">
            Amor en la uno 💖
          </h1>

          <div className="flex gap-2 flex-wrap">
            {chapters.map((chapter) => (
              <button
                key={chapter}
                onClick={() => {
                  setCurrentChapter(chapter);
                  setCurrentPage(0);
                }}
                className="w-12 h-12 rounded-full bg-white shadow-lg"
              >
                {chapter}
              </button>
            ))}
          </div>

          <div className="flex gap-2 flex-wrap">
            {pages.map((_, index) => (
              <button
                key={index}
                onClick={() => setCurrentPage(index)}
                className="w-10 h-10 rounded-full bg-pink-200"
              >
                {index + 1}
              </button>
            ))}
          </div>

        </div>
      </header>

      <main className="max-w-7xl mx-auto px-4 py-10">

        {chapterTitle && (
          <h2 className="text-4xl font-black text-pink-500 mb-4">
            {chapterTitle}
          </h2>
        )}

        {chapterNote && (
          <div className="bg-white rounded-3xl p-5 mb-4 shadow-xl">
            {chapterNote}
          </div>
        )}

        {dedication && (
          <div className="bg-pink-50 rounded-3xl p-5 mb-4 shadow-xl">
            🎀 {dedication}
          </div>
        )}

        {uploadedDocument && (
          <a
            href={uploadedDocument.url}
            download={uploadedDocument.name}
            className="inline-block bg-blue-400 text-white px-5 py-3 rounded-2xl mb-5"
          >
            ⬇ Descargar documento
          </a>
        )}

        <div
          className={`grid gap-6 ${
            doublePage
              ? "grid-cols-1 md:grid-cols-2"
              : "grid-cols-1"
          }`}
        >
          {visiblePages.map((page, index) => (
            <img
              key={index}
              src={page}
              alt=""
              className="rounded-3xl shadow-2xl"
              style={{
                width: `${imageSize}%`,
                margin: "0 auto",
                filter: `brightness(${imageBrightness}%)`,
              }}
            />
          ))}
        </div>

        <div className="flex justify-center gap-4 mt-8">
          <button
            onClick={previousPage}
            className="px-5 py-3 rounded-2xl bg-pink-400 text-white font-bold"
          >
            ⬅ Atrás
          </button>

          <button
            onClick={nextPage}
            className="px-5 py-3 rounded-2xl bg-purple-400 text-white font-bold"
          >
            Siguiente ➡
          </button>
        </div>

      </main>
    </div>
  );
}
