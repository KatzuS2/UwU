
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Amor en la uno 💖</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:sans-serif;
}

body{
background:linear-gradient(to bottom,#ffd6f7,#ead7ff,#d6f0ff);
min-height:100vh;
overflow-x:hidden;
color:#333;
}

header{
position:sticky;
top:0;
z-index:999;
backdrop-filter:blur(15px);
background:rgba(255,255,255,.5);
padding:20px;
border-bottom:2px solid rgba(255,255,255,.5);
}

h1{
font-size:3rem;
font-weight:900;
background:linear-gradient(to right,#ff4fae,#9f5cff,#5caeff);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
margin-bottom:20px;
}

.chapterBar,
.pageButtons,
.imageSelector{
display:flex;
gap:10px;
flex-wrap:wrap;
margin-bottom:15px;
}

button,
.uploadBtn{
border:none;
padding:12px 18px;
border-radius:20px;
cursor:pointer;
font-weight:bold;
transition:.3s;
background:#ff7fc7;
color:white;
box-shadow:0 5px 15px rgba(0,0,0,.15);
}

button:hover,
.uploadBtn:hover{
transform:scale(1.05);
}

.viewer{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(350px,1fr));
gap:20px;
padding:30px;
}

.viewer img{
width:100%;
border-radius:30px;
box-shadow:0 15px 30px rgba(0,0,0,.2);
transition:.3s;
}

.navigation{
display:flex;
justify-content:center;
gap:20px;
padding:30px;
}

.admin{
position:fixed;
right:20px;
top:20px;
width:330px;
max-height:90vh;
overflow-y:auto;
background:rgba(255,255,255,.75);
backdrop-filter:blur(15px);
padding:20px;
border-radius:30px;
z-index:9999;
box-shadow:0 10px 30px rgba(0,0,0,.2);
}

.admin h2{
margin-bottom:15px;
color:#b04cff;
}

.admin h3{
margin-top:15px;
margin-bottom:8px;
color:#ff5db2;
}

input,
textarea,
select{
width:100%;
padding:12px;
border-radius:15px;
border:1px solid #ffc7eb;
margin-bottom:10px;
outline:none;
}

textarea{
min-height:100px;
resize:vertical;
}

.noteBox{
background:white;
padding:20px;
border-radius:25px;
margin:20px;
box-shadow:0 10px 20px rgba(0,0,0,.1);
}

.downloadBtn{
display:inline-block;
padding:12px 20px;
background:#6daeff;
color:white;
border-radius:20px;
text-decoration:none;
font-weight:bold;
margin-top:10px;
}

.selected{
background:#ff4f8f !important;
}

</style>
</head>
<body>

<header>

<h1>Amor en la uno 💖</h1>

<div class="chapterBar" id="chapterBar"></div>

<div id="pageInfo"></div>

<div class="pageButtons" id="pageButtons"></div>

</header>

<div class="admin">

<h2>Panel Admin 🌸</h2>

<input type="text" id="user" placeholder="Usuario">
<input type="password" id="pass" placeholder="Contraseña">

<button onclick="login()">Iniciar sesión 💖</button>

<div id="panel" style="display:none;">

<h3>📚 Elegir capítulo y página</h3>

<select id="uploadChapter"></select>

<input type="number" id="uploadPage" value="1" min="1">

<label class="uploadBtn">
🌸 Subir imágenes
<input hidden type="file" multiple accept="image/*" onchange="uploadImages(event)">
</label>

<h3>🖼 Seleccione imagen</h3>

<div class="imageSelector" id="imageSelector"></div>

<h3>📦 Mover a</h3>

<select id="moveChapter"></select>

<input type="number" id="movePage" value="1" min="1">

<button onclick="moveImage()">📦 Mover imagen</button>

<label class="uploadBtn" style="background:#6db2ff;">
🔄 Reemplazar imagen
<input hidden type="file" accept="image/*" onchange="replaceImage(event)">
</label>

<button onclick="deleteImage()" style="background:#ff6363;">
❌ Borrar imagen
</button>

<h3>📄 Documento</h3>

<label class="uploadBtn" style="background:#b96dff;">
Subir documento
<input hidden type="file" onchange="uploadDocument(event)">
</label>

<button onclick="deleteDocument()" style="background:#ff6363;">
🗑 Eliminar documento
</button>

<div id="documentContainer"></div>

<h3>📝 Título</h3>

<input type="text" id="titleInput" oninput="updateTexts()">

<h3>💖 Nota</h3>

<textarea id="noteInput" oninput="updateTexts()"></textarea>

<h3>🎀 Dedicatoria</h3>

<textarea id="dedicationInput" oninput="updateTexts()"></textarea>

<h3>✨ Brillo</h3>

<input type="range" min="50" max="200" value="100" id="brightness" oninput="renderPages()">

<h3>🖼 Tamaño</h3>

<input type="range" min="50" max="150" value="100" id="size" oninput="renderPages()">

</div>

</div>

<div class="noteBox">
<h2 id="titleView"></h2>
<p id="noteView"></p>
<p id="dedicationView"></p>

<div id="downloadContainer"></div>
</div>

<div class="viewer" id="viewer"></div>

<div class="navigation">
<button onclick="previousPage()">⬅ Atrás</button>
<button onclick="nextPage()">Siguiente ➡</button>
</div>

<script>

const ADMIN_USER="adminuwu";
const ADMIN_PASS="admin123uwu";

let currentChapter=1;
let selectedImage=null;

const chapters=[1,2,3,4,5,6];

let manga=JSON.parse(localStorage.getItem("manga")||"{}");

let documentFile=JSON.parse(localStorage.getItem("documentFile")||"null");

function save(){
localStorage.setItem("manga",JSON.stringify(manga));
}

function login(){

const user=document.getElementById("user").value;
const pass=document.getElementById("pass").value;

if(user===ADMIN_USER && pass===ADMIN_PASS){

document.getElementById("panel").style.display="block";

}else{

alert("❌ Datos incorrectos");

}

}

function createChapters(){

const chapterBar=document.getElementById("chapterBar");

chapters.forEach(ch=>{

const btn=document.createElement("button");

btn.innerText=ch;

btn.onclick=()=>{

currentChapter=ch;
renderPages();

};

chapterBar.appendChild(btn);

const option=document.createElement("option");

option.value=ch;
option.innerText=`Capítulo ${ch}`;

document.getElementById("uploadChapter").appendChild(option.cloneNode(true));

document.getElementById("moveChapter").appendChild(option);

});

}

function uploadImages(event){

const files=[...event.target.files];

const chapter=Number(document.getElementById("uploadChapter").value);

const page=Number(document.getElementById("uploadPage").value)-1;

if(!manga[chapter]){
manga[chapter]=[];
}

files.forEach((file,index)=>{

const reader=new FileReader();

reader.onload=e=>{

manga[chapter].splice(page+index,0,e.target.result);

save();

renderPages();

};

reader.readAsDataURL(file);

});

}

function renderPages(){

const viewer=document.getElementById("viewer");

viewer.innerHTML="";

const pages=manga[currentChapter]||[];

document.getElementById("pageInfo").innerText=`${pages.length} páginas`;

const brightness=document.getElementById("brightness").value;

const size=document.getElementById("size").value;

pages.forEach((img,index)=>{

const image=document.createElement("img");

image.src=img;

image.style.filter=`brightness(${brightness}%)`;

image.style.width=`${size}%`;

viewer.appendChild(image);

});

renderPageButtons();

renderImageSelector();

renderDocument();

}

function renderPageButtons(){

const container=document.getElementById("pageButtons");

container.innerHTML="";

const pages=manga[currentChapter]||[];

pages.forEach((_,index)=>{

const btn=document.createElement("button");

btn.innerText=index+1;

container.appendChild(btn);

});

}

function renderImageSelector(){

const selector=document.getElementById("imageSelector");

selector.innerHTML="";

const pages=manga[currentChapter]||[];

pages.forEach((_,index)=>{

const btn=document.createElement("button");

btn.innerText=index+1;

if(selectedImage===index){
btn.classList.add("selected");
}

btn.onclick=()=>{

selectedImage=index;

renderImageSelector();

};

selector.appendChild(btn);

});

}

function deleteImage(){

if(selectedImage===null)return;

manga[currentChapter].splice(selectedImage,1);

save();

renderPages();

}

function moveImage(){

if(selectedImage===null)return;

const targetChapter=Number(document.getElementById("moveChapter").value);

const targetPage=Number(document.getElementById("movePage").value)-1;

const image=manga[currentChapter][selectedImage];

manga[currentChapter].splice(selectedImage,1);

if(!manga[targetChapter]){
manga[targetChapter]=[];
}

manga[targetChapter].splice(targetPage,0,image);

save();

renderPages();

}

function replaceImage(event){

if(selectedImage===null)return;

const file=event.target.files[0];

const reader=new FileReader();

reader.onload=e=>{

manga[currentChapter][selectedImage]=e.target.result;

save();

renderPages();

};

reader.readAsDataURL(file);

}

function uploadDocument(event){

const file=event.target.files[0];

const reader=new FileReader();

reader.onload=e=>{

documentFile={

name:file.name,
url:e.target.result

};

localStorage.setItem("documentFile",JSON.stringify(documentFile));

renderDocument();

};

reader.readAsDataURL(file);

}

function renderDocument(){

const container=document.getElementById("downloadContainer");

if(!documentFile){

container.innerHTML="";

return;

}

container.innerHTML=`
<a class="downloadBtn" href="${documentFile.url}" download="${documentFile.name}">
⬇ Descargar ${documentFile.name}
</a>
`;

}

function deleteDocument(){

documentFile=null;

localStorage.removeItem("documentFile");

renderDocument();

}

function updateTexts(){

document.getElementById("titleView").innerText=document.getElementById("titleInput").value;

document.getElementById("noteView").innerText=document.getElementById("noteInput").value;

document.getElementById("dedicationView").innerText=document.getElementById("dedicationInput").value;

}

function nextPage(){

window.scrollBy({
top:window.innerHeight,
behavior:"smooth"
});

}

function previousPage(){

window.scrollBy({
top:-window.innerHeight,
behavior:"smooth"
});

}

createChapters();

renderPages();

</script>

</body>
</html>
